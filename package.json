{
  "name": "nodes-play",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run clean && npm run build:tsc",
    "build:swagger": "tsoa spec",
    "build:tsc": "tsc --sourceMap",
    "clean": "rm -rf ./dist/ ./doc/ ./.nyc_output",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint --ignore-path .gitignore --ext .ts,.tsx . && npm run type-check",
    "lint:fix": "eslint --ignore-path .gitignore --ext .ts,.tsx . --fix",
    "format": "prettier --parser typescript --ignore-path .gitignore --write '**/*.{js,jsx,ts,tsx}'",
    "type-check": "tsc --noEmit"
  },
  "author": "",
  "type": "module",
  "license": "ISC",
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^10.1.0",
    "@chainsafe/libp2p-noise": "^13.0.1",
    "@chainsafe/libp2p-yamux": "^5.0.0",
    "@libp2p/bootstrap": "^9.0.5",
    "@libp2p/crypto": "^2.0.3",
    "@libp2p/floodsub": "^8.0.6",
    "@libp2p/interface-address-manager": "^3.0.1",
    "@libp2p/kad-dht": "^10.0.5",
    "@libp2p/mdns": "^9.0.6",
    "@libp2p/mplex": "^9.0.5",
    "@libp2p/peer-id-factory": "^3.0.3",
    "@libp2p/pubsub-peer-discovery": "^8.0.4",
    "@libp2p/tcp": "^8.0.5",
    "@libp2p/websockets": "^7.0.5",
    "@multiformats/multiaddr": "^10.2.0",
    "@nestjs/common": "^10.2.7",
    "@nestjs/core": "^10.2.7",
    "@types/lodash.clonedeep": "^4.5.7",
    "aegir": "^37.3.0",
    "delay": "^5.0.0",
    "hyperdiff": "^2.0.16",
    "it-pipe": "^3.0.1",
    "libp2p": "^0.46.9",
    "lodash.clonedeep": "^4.5.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "stream-concat": "^1.0.0",
    "swagger-ui-express": "^5.0.0",
    "ts-node": "^10.9.1",
    "tsoa": "^5.1.1",
    "uint8arrays": "^4.0.6",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "winston-transport": "^4.6.0"
  },
  "devDependencies": {
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.8.9",
    "@types/swagger-ui-express": "^4.1.3",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "concurrently": "^8.2.1",
    "eslint": "^8.51.0",
    "eslint-config-oceanprotocol": "^2.0.4",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-promise": "^6.1.1",
    "prettier": "^3.0.3",
    "tsx": "^3.12.8"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
